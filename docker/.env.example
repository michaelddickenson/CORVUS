# =============================================================================
# DCO CMS — Production Environment Configuration (Docker)
# =============================================================================
# Copy this file to .env in the repo root (same directory as docker-compose.yml).
# Fill in every value before running `docker compose up -d`.
# NEVER commit .env to version control.
#
# Two PostgreSQL roles are used:
#   dco_owner — full DDL privileges; used by Prisma migrate + seed
#   dco_app   — restricted runtime role; cannot UPDATE or DELETE audit_logs
#
# The passwords you set here must match the ones in DATABASE_URL and
# APP_DATABASE_URL.  Docker Compose passes DB_OWNER_PASSWORD and
# DB_APP_PASSWORD directly to PostgreSQL and to docker/init.sh.
# =============================================================================

# ── PostgreSQL role passwords ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 24
DB_OWNER_PASSWORD=change-this-strong-owner-password
DB_APP_PASSWORD=change-this-different-app-password

# ── Database connection strings ───────────────────────────────────────────────
# Used by Prisma migrate + seed (dco_owner — full privileges)
DATABASE_URL=postgresql://dco_owner:change-this-strong-owner-password@db:5432/dco_cms

# Used by the running Next.js app (dco_app — restricted, cannot mutate audit_logs)
APP_DATABASE_URL=postgresql://dco_app:change-this-different-app-password@db:5432/dco_cms

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-32-plus-character-secret

# Update to your actual deployment URL (no trailing slash).
# Include port if non-standard (e.g. http://cms.corp.local:3000).
NEXTAUTH_URL=http://localhost:3000

# ── Admin bootstrap seed ──────────────────────────────────────────────────────
# These create the initial ADMIN account on first startup (prisma db seed).
# In LDAP mode, the password is owned by AD — SEED_ADMIN_PASSWORD is ignored.
SEED_ADMIN_EMAIL=admin@your-org.example
SEED_ADMIN_NAME=System Administrator
# SEED_ADMIN_PASSWORD=only-needed-for-credential-demo-mode

# ── LDAP / Active Directory ───────────────────────────────────────────────────
# Set all four vars to enable LDAP authentication (production).
# Leave unset to fall back to credential auth (demo mode only — see below).
LDAP_URI=ldap://dc01.corp.local:389
LDAP_BASE_DN=DC=corp,DC=local
LDAP_BIND_DN=CN=svc-dco,OU=ServiceAccounts,DC=corp,DC=local
LDAP_BIND_PASSWORD=service-account-password

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=50

# ── Application version (optional) ───────────────────────────────────────────
# Displayed in Admin → Overview. Set during CI/CD if desired.
# APP_VERSION=1.0.0

# ── Credential / demo auth ────────────────────────────────────────────────────
# WARNING: Do NOT enable in production LDAP deployments.
# Only set these for local development or demo environments.
# ENABLE_CREDENTIAL_AUTH=true
# NEXT_PUBLIC_DEMO_MODE=true
