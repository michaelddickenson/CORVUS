# =============================================================================
# DCO Case Management System — Environment Variables
# Copy this file to .env and fill in values. NEVER commit .env to the repo.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string.
# Docker Compose example: postgresql://dco:changeme@db:5432/dco_cms
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/dco_cms?schema=public"

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------
# 32+ character random secret for session signing.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-plus-character-secret"

# Full URL of this deployment (no trailing slash).
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Admin bootstrap seed (prisma/seed.ts)
# Run once on first startup: npx prisma db seed
# The seed is idempotent — safe to re-run.
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_NAME="System Administrator"

# Required only in demo / credential mode (set ENABLE_CREDENTIAL_AUTH=true below).
# In LDAP deployments the seed still creates the user record but leaves password null.
SEED_ADMIN_PASSWORD="change-me-before-seeding"

# -----------------------------------------------------------------------------
# LDAP / Active Directory (production only)
# Leave these unset for local dev / demo deployments.
# -----------------------------------------------------------------------------
# LDAP_URI="ldap://dc01.corp.local:389"
# LDAP_BASE_DN="DC=corp,DC=local"
# LDAP_BIND_DN="CN=svc-dco,OU=ServiceAccounts,DC=corp,DC=local"
# LDAP_BIND_PASSWORD="service-account-password"

# -----------------------------------------------------------------------------
# Demo / credential auth (Vercel / local dev only)
# Set to "true" to enable the email+password login flow.
# NEVER set this in a production (Docker / AD-connected) deployment.
# -----------------------------------------------------------------------------
# ENABLE_CREDENTIAL_AUTH="true"

# -----------------------------------------------------------------------------
# Admin panel — user creation default (Phase 7)
# -----------------------------------------------------------------------------
# Password assigned to newly created users when no password is provided in the
# POST /api/admin/users request body. Only applies in credential (demo) mode.
# The temporary password is returned once in the API response; instruct the user
# to change it on first login.
# DEFAULT_USER_PASSWORD="ChangeMe1!"

# -----------------------------------------------------------------------------
# File uploads (Phase 6)
# -----------------------------------------------------------------------------
# Maximum upload size in megabytes. Default: 50
# MAX_UPLOAD_MB="50"

# Absolute path on the server where uploaded files are stored.
# Must be outside the web root. In Docker, map a named volume here.
# UPLOAD_STORAGE_PATH="/var/dco/uploads"
